{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "./dist/webview",
    "types": ["vite/client"]
  },
  "include": ["src/webview/**/*.ts", "src/webview/**/*.tsx"],
  "exclude": ["src/host", "node_modules", "dist"]
}
